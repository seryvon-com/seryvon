# Seryvon — exemple de configuration d'environnement.
# Copier en `.env` et compléter. Ne JAMAIS committer le `.env` réel.

# --- Base de données / broker ---
SERYVON_DATABASE_URL=postgresql+psycopg://seryvon:seryvon@localhost:5432/seryvon
SERYVON_REDIS_URL=redis://localhost:6379/0
SERYVON_CELERY_BROKER_URL=redis://localhost:6379/1
SERYVON_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Crawl ---
SERYVON_USER_AGENT=Seryvon/0.1 (+https://seryvon.com/bot)
SERYVON_MAX_PAGES=200
SERYVON_MAX_DEPTH=3
SERYVON_RESPECT_ROBOTS=true

# --- Chiffrement BYOK (clés API utilisateur, chiffrées au repos) ---
# Générer avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SERYVON_SECRET_KEY=

# --- APIs externes gratuites (optionnelles en Phase 0) ---
PSI_API_KEY=
OPR_API_KEY=

# --- APIs externes BYOK (phases ultérieures) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

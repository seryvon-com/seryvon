{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "api",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "seryvon.api.main:app", "--reload", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "worker",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "celery", "-A", "seryvon.tasks.app", "worker", "--loglevel=info", "-Q", "cpu,celery"],
      "port": 6379,
      "autoPort": true
    }
  ]
}
